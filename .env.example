# Server Configuration
SERVER_PORT=3000
ADMIN_TOKEN=your-secure-admin-token-here

# Primary Provider Configuration
# Example: OpenAI
PRIMARY_TYPE=openai-compatible
PRIMARY_API_KEY=sk-your-openai-api-key-here
PRIMARY_BASE_URL=https://api.openai.com/v1
PRIMARY_MODELS=gpt-4o,gpt-4o-mini,gpt-3.5-turbo
PRIMARY_TIMEOUT_MS=60000
PRIMARY_ENABLED=true
PRIMARY_PRIORITY=10

# Fallback Provider Configuration (Optional)
# Example: Anthropic
# FALLBACK_TYPE=anthropic
# FALLBACK_API_KEY=sk-ant-your-anthropic-api-key-here
# FALLBACK_BASE_URL=https://api.anthropic.com
# FALLBACK_MODELS=claude-sonnet-4-20250514,claude-3-5-sonnet-20241022
# FALLBACK_TIMEOUT_MS=60000
# FALLBACK_ENABLED=true
# FALLBACK_PRIORITY=20

# Additional Provider Examples

# Azure OpenAI
# AZURE_TYPE=azure
# AZURE_API_KEY=your-azure-api-key
# AZURE_BASE_URL=https://your-resource.openai.azure.com
# AZURE_MODELS=gpt-4o-deployment-name
# AZURE_ENABLED=true
# AZURE_PRIORITY=15

# Google AI
# GOOGLE_TYPE=google
# GOOGLE_API_KEY=your-google-api-key
# GOOGLE_MODELS=gemini-1.5-pro,gemini-1.5-flash
# GOOGLE_ENABLED=true
# GOOGLE_PRIORITY=20

# Ollama (Local)
# OLLAMA_TYPE=openai-compatible
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODELS=llama3.1:70b,mistral:latest
# OLLAMA_ENABLED=true
# OLLAMA_PRIORITY=30

# Redis Configuration (Optional - enables caching and rate limiting)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# SSE Heartbeat for Streaming (milliseconds)
# Prevents connection timeout during long-running streaming requests
SSE_HEARTBEAT_INTERVAL_MS=15000

# Semantic Cache Configuration (Optional)
SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.15
SEMANTIC_CACHE_EMBEDDING_MODEL=text-embedding-3-small

# Logging
LOG_LEVEL=info

# Admin UI
ADMIN_UI_ENABLED=true
ADMIN_UI_PORT=5173
